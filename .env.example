# Required for production URL, sitemap, canonicals, and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS for client builds. Leave blank only for starter/local fallback work.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-24

# Optional Sanity draft/live preview and webhook revalidation.
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# Optional Resend contact provider. Server-only; never expose in browser code.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=

# Optional Search Console verification token.
GOOGLE_SITE_VERIFICATION=
